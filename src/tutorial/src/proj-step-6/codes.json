  {
    "name": "web/src/assets/global.css",
    "lang": "css",
    "code": "/* =============================================================\n   全局样式 + 设计变量\n   ============================================================= */\n\n:root {\n  /* 色板 */\n  --bg-base:      #fafafa;\n  --bg-elevated:  #ffffff;\n  --bg-subtle:    #f4f4f5;\n  --bg-muted:     #e4e4e7;\n\n  /* 侧栏深色调（zinc 系，类 ChatGPT 视觉） */\n  --side-bg:        #18181b;\n  --side-bg-hover:  #27272a;\n  --side-bg-active: #3f3f46;\n  --side-border:    #27272a;\n  --side-text:      #e4e4e7;\n  --side-text-mute: #a1a1aa;\n  --side-text-dim:  #71717a;\n\n  /* 文字 */\n  --text:           #18181b;\n  --text-muted:     #52525b;\n  --text-dim:       #a1a1aa;\n\n  /* 边框 */\n  --border:         #e4e4e7;\n  --border-strong:  #d4d4d8;\n\n  /* 强调色（克制版紫蓝） */\n  --accent:         #4f46e5;\n  --accent-hover:   #4338ca;\n  --accent-light:   #eef2ff;\n\n  /* 状态 */\n  --success:        #10b981;\n  --warn:           #f59e0b;\n  --danger:         #ef4444;\n  --danger-bg:      #fef2f2;\n\n  /* 形状 */\n  --radius-sm: 6px;\n  --radius:    10px;\n  --radius-lg: 14px;\n\n  /* 阴影 */\n  --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.04);\n  --shadow:    0 4px 16px -4px rgba(0, 0, 0, 0.08);\n  --shadow-lg: 0 20px 50px -20px rgba(0, 0, 0, 0.18);\n}\n\n*,\n*::before,\n*::after { box-sizing: border-box; }\n\nhtml, body, #app { height: 100%; margin: 0; }\n\nbody {\n  font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI',\n               'PingFang SC', 'Microsoft YaHei', sans-serif;\n  font-size: 14px;\n  color: var(--text);\n  background: var(--bg-base);\n  -webkit-font-smoothing: antialiased;\n  text-rendering: optimizeLegibility;\n}\n\na { color: inherit; text-decoration: none; }\n\nbutton {\n  font: inherit;\n  cursor: pointer;\n  background: none;\n  border: none;\n  padding: 0;\n  color: inherit;\n}\n\ninput, textarea, select {\n  font: inherit;\n  color: inherit;\n}\n\n::-webkit-scrollbar { width: 8px; height: 8px; }\n::-webkit-scrollbar-thumb { background: rgba(0, 0, 0, 0.12); border-radius: 4px; }\n::-webkit-scrollbar-thumb:hover { background: rgba(0, 0, 0, 0.22); }\n::-webkit-scrollbar-track { background: transparent; }\n\n/* 侧栏内的滚动条用浅色 */\n.dark-scroll::-webkit-scrollbar-thumb { background: rgba(255, 255, 255, 0.08); }\n.dark-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255, 255, 255, 0.16); }\n"
